# ── App ──
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/flavor_template?schema=public
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=flavor_template

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Auth ──
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Payment: MoMo (if needed) ──
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=
# MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api

# ── Payment: PayOS (if needed) ──
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=

# ── Email: SMTP (if needed) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@flavor_template.com

# ── Storage: Cloudflare R2 (if needed) ──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
